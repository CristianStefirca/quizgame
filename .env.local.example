# Upstash Redis (auto-injected by the Vercel marketplace integration).
# For local dev, copy this file to .env.local and paste values from
# your Upstash dashboard: https://console.upstash.com/
# (Project -> your database -> REST API -> .env)
#
# These are also the names Vercel KV / Upstash integration sets automatically
# when you add the integration in Vercel -> Storage -> Upstash.
KV_REST_API_URL=
KV_REST_API_TOKEN=
# Or use the equivalent UPSTASH_* names if you created the DB directly on Upstash:
# UPSTASH_REDIS_REST_URL=
# UPSTASH_REDIS_REST_TOKEN=
