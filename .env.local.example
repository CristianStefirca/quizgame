# This file is documented for local development. The Firebase Functions runtime
# does not use env vars — it loads service account credentials directly from
# the Firebase project configuration when deployed via firebase deploy.

# For local development (Next.js dev server — same落前的 behavior):
# Copy this file to .env.local and optionally fill in Firebase service account.
# If empty, the app degrades gracefully to localStorage-only persistence.
FIREBASE_SERVICE_ACCOUNT=

# Alternative - local dev only - path to service account JSON file on disk:
# GOOGLE_APPLICATION_CREDENTIALS=/path/to/serviceAccountKey.json